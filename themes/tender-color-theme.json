// This theme's colors are based on the original tender
// # reds
//  	red1: '#f43753'
//  	red2: '#c5152f'
//  	red3: '#79313c'
//
// # blues
//  	blue1: '#b3deef'
//  	blue2: '#73cef4'
//  	blue3: '#44778d'
//  	blue4: '#335261'
//  	blue5: '#293b44'
//
// # greens
//  	green1: '#c9d05c'
//  	green2: '#9faa00'
//  	green3: '#6a6b3f'
//  	green4: '#464632'
//
// # yellows
//  	yellow1: '#d3b987'
//  	yellow2: '#ffc24b'
//  	yellow3: '#715b2f'
//
// # whites
//  	highlighted: '#ffffff'
//  	text: '#eeeeee'
//  	pearl: '#dadada'
//
// # greys
//  	gandalf: '#bbbbbb'
//  	grey1: '#999999'
//  	grey2: '#666666'
//  	grey3: '#444444'
//
//  shadow: '#323232'
//  bg: '#282828'
//
//  dark: '#202020'
//  darker: '#1d1d1d'
//  darkest: '#000000'
{
	"name": "Tender",
	"type": "dark",
	"colors": {
    // Base colors
		"focusBorder": "#666666",
		"widget.shadow": "#32323298",
		"selection.background": "#dadada",
    // Button control
		"button.background": "#666666",
    // Dropdown control
		"dropdown.background": "#444444",
		"dropdown.listBackground": "#1d1d1d",
    // Input control
		"input.background": "#444444",
		"inputOption.activeBorder": "#666666",
		"inputValidation.errorBackground": "#90274A", // middle of #282828 and #f92672
		"inputValidation.errorBorder": "#f92672",
		"inputValidation.infoBackground": "#546190", // middle of #282828 and #819aff
		"inputValidation.infoBorder": "#819aff",
		"inputValidation.warningBackground": "#848528", // middle of #282828 and #e2e22e
		"inputValidation.warningBorder": "#e2e22e",
    // Badge
		"badge.background": "#666666",
		"badge.foreground": "#eeeeee",
    // Progress bar
		"progressBar.background": "#666666",
    // Lists and trees
		"list.activeSelectionBackground": "#666666",
		"list.dropBackground": "#444444",
		"list.focusBackground": "#444444",
		"list.highlightForeground": "#eeeeee",
		"list.hoverBackground": "#323232",
		"list.inactiveSelectionBackground": "#444444",
    // Activity Bar
		"activityBar.background": "#282828",
		"activityBar.foreground": "#eeeeee",
    // Side Bar
		"sideBar.background": "#1d1d1d",
		"sideBarSectionHeader.background": "#282828",
    // Minimap
		"minimap.selectionHighlight": "#99999980",
    // Editor Groups & Tabs
		"editorGroup.border": "#323232",
		"editorGroup.dropBackground": "#44444480",
		"editorGroupHeader.tabsBackground": "#1d1d1d",
		"tab.border": "#1d1d1d",
		"tab.lastPinnedBorder": "#444444",
		"tab.inactiveBackground": "#323232",
		"tab.inactiveForeground": "#dadada", // needs to be bright so it's readable when another editor group is focused
    // Editor colors
		"editor.background": "#282828",  // base.yml Normal: 'text bg'
		"editor.foreground": "#eeeeee",  // base.yml Normal: 'text bg'
		"editorLineNumber.foreground": "#444444",  // base.yml LineNr: 'grey3 -'
		"editorLineNumber.activeForeground": "#73cef4", //base.yml CursorLineNr: 'blue2 - '
		"editorCursor.background": "#323232",  // base.yml CursorLine: '- shadow'
		"editor.selectionBackground": "#99999980",
		"editor.selectionHighlightBackground": "#66666680",
		"editor.wordHighlightBackground": "#44444480",
		"editor.wordHighlightStrongBackground": "#66666680",
		"editor.lineHighlightBackground": "#323232",
		"editorWhitespace.foreground": "#444444",
		"editorIndentGuide.background": "#444444",
		"editorIndentGuide.activeBackground": "#666666",
    // Diff editor colors
		"diffEditor.insertedTextBackground": "#46463280", // base.yml DiffAdd: '- green4'
		"diffEditor.removedTextBackground": "#79313c80", // base.yml DiffDelete: 'red1 red3'
    // Editor widget colors
		"editorWidget.background": "#1d1d1d",
		"editorSuggestWidget.background": "#282828",
		"editorSuggestWidget.border": "#666666",
		"editorHoverWidget.background": "#444444",
		"editorHoverWidget.border": "#666666",
    // Peek view colors
		"peekView.border": "#666666",
		"peekViewEditor.background": "#282828",
		"peekViewEditor.matchHighlightBackground": "#666666",
		"peekViewResult.background": "#1d1d1d",
		"peekViewResult.matchHighlightBackground": "#666666",
		"peekViewResult.selectionBackground": "#444444",
		"peekViewTitle.background": "#1d1d1d",
    // Panel colors
		"panel.border": "#444444",
		"panelTitle.activeBorder": "#666666",
		"panelTitle.activeForeground": "#eeeeee",
		"panelTitle.inactiveForeground": "#666666",
    // Status Bar colors
		"statusBar.background": "#44778d", // lightline/regular.yml normal3: 'blue1 blue3'
		"statusBar.foreground": "#b3deef", // lightline/regular.yml normal3: 'blue1 blue3'
		"statusBar.debuggingBackground": "#715b2f", // lightline/regular.yml visual3: 'yellow1 yellow3'
		"statusBar.debuggingForeground": "#d3b987", // lightline/regular.yml visual3: 'yellow1 yellow3'
		"statusBar.noFolderForeground": "#bbbbbb", // lightline/regular.yml inactive3: 'gandalf grey3'
		"statusBar.noFolderBackground": "#444444", // lightline/regular.yml inactive3: 'gandalf grey3'
		"statusBarItem.remoteBackground": "#6a6b3f", // lightline/regular.yml insert3: 'green1 green3'
		"statusBarItem.remoteForeground": "#c9d05c", // lightline/regular.yml insert3: 'green1 green3'
		"statusBarItem.errorBackground": "#79313c", // lightline/regular.yml replace3: 'red1 red3'
		"statusBarItem.errorForeground": "#f43753", // lightline/regular.yml replace3: 'red1 red3'
    // Title Bar colors
		"titleBar.activeBackground": "#1d1d1d",
    // Menu Bar colors
		"menu.background": "#1d1d1d",
		"menu.foreground": "#dadada",
    // Quick picker colors
		"pickerGroup.foreground": "#666666",
    // Integrated Terminal colors
	    // from tender.vim/estilo/addons/nvim-term.yml
		"terminal.ansiBlack": "#282828", // color_0: 'bg'
		"terminal.ansiRed": "#f43753", // color_1: 'red1'
		"terminal.ansiGreen": "#c9d05c", // color_2: 'green1'
		"terminal.ansiYellow": "#ffc24b", // color_3: 'yellow2'
		"terminal.ansiBlue": "#b3deef", // color_4: 'blue1'
		"terminal.ansiMagenta": "#d3b987", // color_5: 'yellow1'
		"terminal.ansiCyan": "#73cef4", // color_6: 'blue2'
		"terminal.ansiWhite": "#eeeeee", // color_7: 'text'
		"terminal.ansiBrightBlack": "#1d1d1d", // color_8: 'darker'
		"terminal.ansiBrightRed": "#f43753", // color_9: 'red1'
		"terminal.ansiBrightGreen": "#c9d05c", // color_10: 'green1'
		"terminal.ansiBrightYellow": "#ffc24b", // color_11: 'yellow2'
		"terminal.ansiBrightBlue": "#b3deef", // color_12: 'blue1'
		"terminal.ansiBrightMagenta": "#d3b987", // color_13: 'yellow1'
		"terminal.ansiBrightCyan": "#73cef4", // color_14: 'blue2'
		"terminal.ansiBrightWhite": "#ffffff", // color_15: 'highlighted'
    // Debug color
		"debugToolBar.background": "#1d1d1d",
    // Settings Editor colors
		"settings.focusedRowBackground": "#4444445A",
	},
	"tokenColors": [
		{
			"name": "Comment",
			"scope": "comment",
			"settings": {
				"foreground": "#666666" // base.yml Comment: 'grey2'
			}
		},
		{
			"name": "String",
			"scope": "string",
			"settings": {
				"foreground": "#d3b987" // base.yml String: 'yellow1 -'
			}
		},
		{
			"name": "Template Definition",
			"scope": [
				"punctuation.definition.template-expression",
				"punctuation.section.embedded"
			],
			"settings": {
				"foreground": "#73cef4"
			}
		},
		{
			"name": "Reset JavaScript string interpolation expression",
			"scope": [
				"meta.template.expression"
			],
			"settings": {
				"foreground": "#F8F8F2"
			}
		},
		{
			"name": "Number",
			"scope": "constant.numeric",
			"settings": {
				"foreground": "#ffc24b" // base.yml Number: 'yellow2 -'
			}
		},
		{
			"name": "Built-in constant",
			"scope": "constant.language",
			"settings": {
				"foreground": "#ffc24b" // base.yml Constant: 'yellow2 -'
			}
		},
		{
			"name": "User-defined constant",
			"scope": "constant.character, constant.other",
			"settings": {
				"foreground": "#73cef4" // base.yml SpecialChar: 'blue2 -'
			}
		},
		{
			"name": "Keyword",
			"scope": "keyword",
			"settings": {
				"foreground": "#b3deef" // base.yml Keyword: 'blue1 -'
			}
		},
		{
			"name": "Keyword Control",
			"scope": "keyword.control",
			"settings": {
				"foreground": "#c9d05c" // base.yml Conditional: 'green1 -'
			}
		},
		{
			"name": "Keyword Operator",
			"scope": "keyword.operator",
			"settings": {
				"foreground": "#f43753" // base.yml Operator: 'red1 -'
			}
		},
		{
			"name": "Storage",
			"scope": "storage",
			"settings": {
				"fontStyle": "",
				"foreground": "#73cef4" // base.yml StorageClass: 'blue2 -'
			}
		},
		{
			"name": "Storage type",
			"scope": "storage.type",
			"settings": {
				"fontStyle": "italic",
				"foreground": "#73cef4" // base.yml StorageClass: 'blue2 -'
			}
		},
		{
			"name": "Class name",
			"scope": "entity.name.type, entity.name.class, entity.name.namespace, entity.name.scope-resolution",
			"settings": {
				"fontStyle": "underline",
				"foreground": "#73cef4" // base.yml StorageClass: 'blue2 - '
			}
		},
		{
			"name": "Inherited class",
			"scope": "entity.other.inherited-class",
			"settings": {
				"fontStyle": "italic underline",
				"foreground": "#73cef4" // base.yml StorageClass: 'blue2 - '
			}
		},
		{
			"name": "Function name",
			"scope": "entity.name.function",
			"settings": {
				"fontStyle": "",
				"foreground": "#b3deef" // base.yml Function: 'blue1 -'
			}
		},
		{
			"name": "Function argument",
			"scope": "variable.parameter",
			"settings": {
				"fontStyle": "italic",
				"foreground": "#b3deef" // base.yml Function: 'blue1 -'
			}
		},
		{
			"name": "Tag name",
			"scope": "entity.name.tag",
			"settings": {
				"fontStyle": "",
				"foreground": "#b3deef" // html.yml htmlTag: 'blue1 -'
			}
		},
		{
			"name": "Tag attribute",
			"scope": "entity.other.attribute-name",
			"settings": {
				"fontStyle": "",
				"foreground": "#73cef4" // html.yml htmlArg 'blue2 - '
			}
		},
		{
			"name": "Library function",
			"scope": "support.function",
			"settings": {
				"fontStyle": "",
				"foreground": "#b3deef" // base.yml Function: 'blue1 -'
			}
		},
		{
			"name": "Library constant",
			"scope": "support.constant",
			"settings": {
				"fontStyle": "",
				"foreground": "#ffc24b" // base.yml Constant: 'yellow2 -'
			}
		},
		{
			"name": "Library class/type",
			"scope": "support.type, support.class",
			"settings": {
				"fontStyle": "italic",
				"foreground": "#73cef4" // base.yml StorageClass: 'blue2 - '
			}
		},
		{
			"name": "Library variable",
			"scope": "support.other.variable",
			"settings": {
				"fontStyle": ""
			}
		},
		{
			"name": "Invalid",
			"scope": "invalid",
			"settings": {
				"fontStyle": "",
				"foreground": "#F44747"
			}
		},
		{
			"name": "Invalid deprecated",
			"scope": "invalid.deprecated",
			"settings": {
				"foreground": "#F44747"
			}
		},
		{
			"name": "JSON String",
			"scope": "meta.structure.dictionary.json string.quoted.double.json",
			"settings": {
				"foreground": "#CFCFC2"
			}
		},
		{
			"name": "diff.header",
			"scope": "meta.diff, meta.diff.header",
			"settings": {
				"foreground": "#666666"
			}
		},
		{
			"name": "diff.deleted",
			"scope": "markup.deleted",
			"settings": {
				"foreground": "#F92672"
			}
		},
		{
			"name": "diff.inserted",
			"scope": "markup.inserted",
			"settings": {
				"foreground": "#A6E22E"
			}
		},
		{
			"name": "diff.changed",
			"scope": "markup.changed",
			"settings": {
				"foreground": "#E6DB74"
			}
		},
		{
			"scope": "constant.numeric.line-number.find-in-files - match",
			"settings": {
				"foreground": "#AE81FFA0"
			}
		},
		{
			"scope": "entity.name.filename.find-in-files",
			"settings": {
				"foreground": "#E6DB74"
			}
		},
		{
			"name": "Markup Quote",
			"scope": "markup.quote",
			"settings": {
				"foreground": "#F92672"
			}
		},
		{
			"name": "Markup Lists",
			"scope": "markup.list",
			"settings": {
				"foreground": "#E6DB74"
			}
		},
		{
			"name": "Markup Styling",
			"scope": "markup.bold, markup.italic",
			"settings": {
				"foreground": "#66D9EF"
			}
		},
		{
			"name": "Markup Inline",
			"scope": "markup.inline.raw",
			"settings": {
				"fontStyle": "",
				"foreground": "#FD971F"
			}
		},
		{
			"name": "Markup Headings",
			"scope": "markup.heading",
			"settings": {
				"foreground": "#A6E22E"
			}
		},
		{
			"name": "Markup Setext Header",
			"scope": "markup.heading.setext",
			"settings": {
				"foreground": "#A6E22E",
				"fontStyle": "bold"
			}
		},
		{
			"name": "Markup Headings",
			"scope": "markup.heading.markdown",
			"settings": {
				"fontStyle": "bold"
			}
		},
		{
			"name": "Markdown Quote",
			"scope": "markup.quote.markdown",
			"settings": {
				"fontStyle": "italic",
				"foreground": "#666666"
			}
		},
		{
			"name": "Markdown Bold",
			"scope": "markup.bold.markdown",
			"settings": {
				"fontStyle": "bold"
			}
		},
		{
			"name": "Markdown Link Title/Description",
			"scope": "string.other.link.title.markdown,string.other.link.description.markdown",
			"settings": {
				"foreground": "#AE81FF"
			}
		},
		{
			"name": "Markdown Underline Link/Image",
			"scope": "markup.underline.link.markdown,markup.underline.link.image.markdown",
			"settings": {
				"foreground": "#E6DB74"
			}
		},
		{
			"name": "Markdown Emphasis",
			"scope": "markup.italic.markdown",
			"settings": {
				"fontStyle": "italic"
			}
		},
		{
			"name": "Markdown Punctuation Definition Link",
			"scope": "markup.list.unnumbered.markdown, markup.list.numbered.markdown",
			"settings": {
				"foreground": "#eeeeee"
			}
		},
		{
			"name": "Markdown List Punctuation",
			"scope": [
				"punctuation.definition.list.begin.markdown"
			],
			"settings": {
				"foreground": "#A6E22E"
			}
		},
		{
			"scope": "token.info-token",
			"settings": {
				"foreground": "#6796e6"
			}
		},
		{
			"scope": "token.warn-token",
			"settings": {
				"foreground": "#cd9731"
			}
		},
		{
			"scope": "token.error-token",
			"settings": {
				"foreground": "#f44747"
			}
		},
		{
			"scope": "token.debug-token",
			"settings": {
				"foreground": "#b267e6"
			}
		},
		{
			"name": "this.self",
			"scope": "variable.language",
			"settings": {
				"foreground": "#FD971F"
			}
		}
	],
}