{
	"name": "Tender",
	"type": "dark",
	"colors": {
    // Base colors
	    "errorForeground": "#f43753", // base.yml ErrorMsg: 'red1 - r'
    // Input control
	    "inputValidation.errorBackground": "#f43753", // base.yml Error: 'text red1'
		"inputValidation.errorForeground": "#eeeeee", // base.yml Error: 'text red1'
	// Editor colors
		"editor.background": "#282828", // base.yml Normal: 'text bg'
		"editor.foreground": "#eeeeee", // base.yml Normal: 'text bg'
		"editorLineNumber.foreground": "#444444", // base.yml LineNr: 'grey3 -'
		"editorLineNumber.activeForeground": "#73cef4", // base.yml CursorLineNr: 'blue2 -'
		"editorCursor.background": "#323232", // base.yml CursorLine: '- shadow'
		// Folding
		"editor.foldBackground": "#202020", // base.yml Folded: 'grey2 dark'
    // Diff editor colors
		"diffEditor.insertedTextBackground": "#464632", // base.yml DiffAdd: '- green4'
		"diffEditor.removedTextBackground": "#79313c" // base.yml DiffDelete: 'red1 red3'
	},
	"tokenColors": [
		{
			"name": "Comment",
			"scope": [
				"comment",
				"punctuation.definition.comment"
			],
			"settings": {
				"fontStyle": "italic",
				"foreground": "#666666"
			}
		},
	]
}